[
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\u001b[13;2u" },
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\u001b[13;5u" },
    "when": "terminalFocus"
  },
  {
    "key": "alt+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\u001b[13;3u" },
    "when": "terminalFocus"
  }
]
