// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "debugger": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "left",
  },
  "active_pane_modifiers": {
    "border_size": 2.0,
    "inactive_opacity": 0.7,
  },
  "agent": {
    "favorite_models": [],
    "model_parameters": [],
    "enable_feedback": false,
    // disable for now, waiting for pi-acp to be more mature
    "enabled": false,
    "button": false,
  },
  "context_servers": {},
  "minimap": {
    "thumb": "always",
    "display_in": "active_editor",
    "show": "auto",
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "button": false,
  },
  "ui_font_family": ".SystemUIFont",
  "buffer_line_height": "comfortable",
  "auto_update": false,
  "edit_predictions": {
    "provider": "copilot",
    "allow_data_collection": "no",
    "open_ai_compatible_api": {
      "model": "",
      "api_url": "",
    },
  },
  "agent_servers": {
    "pibox": {
      "type": "custom",
      "command": "/home/marchambault/develop/github.com/badjware/pibox/launch.sh",
      "args": ["--acp", "--unsafe-enable-docker"],
      "env": {},
    },
    "pibox-read-only": {
      "type": "custom",
      "command": "/home/marchambault/develop/github.com/badjware/pibox/launch.sh",
      "args": ["--acp", "--read-only"],
      "env": {},
    },
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "font_family": "Hack Nerd Font",
    "font_fallbacks": ["monospace"],
  },
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": ["monospace", "Font Awesome 5 Pro"],
  "buffer_font_family": "Hack",
  "ui_font_size": 16.0,
  "buffer_font_size": 14.0,
  "theme": "Ayu Mirage",
}
