#!/bin/sh
sunshine_output_restore_cache="$XDG_RUNTIME_DIR/sunshine_output_restore_cache"

is_headless_active() {
    swaymsg -t get_outputs \
        | jq -e '.[] | select(.name == "HEADLESS-1" and .active == true)' > /dev/null 2>&1
}

if [[ is_headless_active || -f "$sunshine_output_restore_cache" ]]; then
    printf 'Monitor: HEADLESS-1\n'
else
    slurp -f 'Monitor: %o' -or
fi
