# Rebind prefix to `
unbind C-b
set-option -g prefix `
bind-key ` send-prefix
# Rebind split to - and |
unbind '"'
unbind %
bind | split-window -h
bind - split-window -v
# Bind config reloading
bind r source-file ~/.tmux.conf \; display-message 'Config reloaded...'

# Escape delay is anoying in vim
set -s escape-time 0

# True color
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*256col*:RGB"

# Mouse
set -g mouse on

# Copy-mode: vi keys, yank to system clipboard via wl-copy
setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-pipe-and-cancel 'wl-copy'
bind -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel 'wl-copy'

# Window
set -g base-index 1

# Pane
setw -g pane-base-index 1
setw -g allow-rename off
set -g pane-border-style fg='{{ template "color-hex" "tertiary" }}'
set -g pane-active-border-style fg='{{ template "color-hex" "primary" }}'

# Status bar
set -g status-position top
set -g status-style 'bg=default,fg={{ template "color-hex" "on_background" }}'
set -g status-justify left

# Windows: inactive plain on_background, active = primary pill (matches waybar focused workspace)
setw -g window-status-style fg='{{ template "color-hex" "on_background" }}'
setw -g window-status-format ' #I:#W '
setw -g window-status-current-style fg='{{ template "color-hex" "on_primary" }}',bg='{{ template "color-hex" "primary" }}',bold
setw -g window-status-current-format ' #I:#W '
setw -g window-status-activity-style fg='{{ template "color-hex" "error" }}',bold

# Left: empty (window list pinned to left)
set -g status-left ''

# Right: session name styled like waybar #mode (secondary fg, tertiary separator)
set -g status-right-length 60
set -g status-right-style fg='{{ template "color-hex" "secondary" }}'
set -g status-right '#[fg={{ template "color-hex" "error" }},bold]#{?client_prefix,● ,}#[fg={{ template "color-hex" "secondary" }},bold]#S '

# Plugins
# Resurect pane content
set -g @resurrect-capture-pane-contents 'on'
# additional process to restore
set -g @resurrect-processes 'ssh watch'

# Save every 5 minutes
set -g @continuum-save-interval '5'

# Restore on session start
#set -g @continuum-restore 'on'

# List of plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
# prefix + I : install
# prefix + U : update
# prefix + alt + u : cleanup
run -b '~/.tmux/plugins/tpm/tpm'
